rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Since this is a server-side app, we allow all for now but in a real app 
    // we would restrict this to the server service account.
    // However, for this environment, we'll allow public for simplicity if needed, 
    // but the backend uses admin SDK so it bypasses rules.
    // For the frontend to read inventory, we allow read.
    
    match /inventory/{itemId} {
      allow read, write: if true;
    }
    
    match /logs/{logId} {
      allow read, write: if true;
    }
    
    match /messages/{messageId} {
      allow read, write: if true;
    }
  }
}
