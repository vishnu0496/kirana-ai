# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# WHATSAPP_TOKEN: The temporary or permanent access token from Meta for Developers.
WHATSAPP_TOKEN="YOUR_WHATSAPP_TOKEN"

# WHATSAPP_PHONE_NUMBER_ID: The ID of your WhatsApp phone number from Meta for Developers.
WHATSAPP_PHONE_NUMBER_ID="YOUR_PHONE_NUMBER_ID"

# WHATSAPP_VERIFY_TOKEN: A secret string you choose for webhook verification.
WHATSAPP_VERIFY_TOKEN="KIRANA_SECRET"
